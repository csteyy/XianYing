VITE_VOLCENGINE_API_KEY=your_api_key_here
VITE_VOLCENGINE_STREAM_RESOURCE_ID=volc.seedasr.sauc.duration
VITE_VOLCENGINE_FILE_RESOURCE_ID=volc.seedasr.auc
VITE_AUDIO_UPLOAD_ENDPOINT=http://localhost:3001/upload-audio

# TOS object storage (server-side only, used by wsProxy.ts)
TOS_ACCESS_KEY_ID=your_access_key_here
TOS_SECRET_ACCESS_KEY=your_secret_key_here
TOS_REGION=cn-beijing
TOS_BUCKET=your_bucket_name
TOS_ENDPOINT=tos-cn-beijing.volces.com

# TOS (client-side, for iOS native direct upload)
VITE_TOS_ACCESS_KEY_ID=
VITE_TOS_SECRET_ACCESS_KEY=
VITE_TOS_REGION=cn-beijing
VITE_TOS_BUCKET=
VITE_TOS_ENDPOINT=tos-cn-beijing.volces.com

# Google Sheets
VITE_GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# Google Service Account (for iOS native direct Sheets API access)
VITE_GSHEETS_CLIENT_EMAIL=
VITE_GSHEETS_PRIVATE_KEY=

# Title Generation LLM (Volcengine ARK, OpenAI-compatible)
VITE_TITLE_LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VITE_TITLE_LLM_MODEL=deepseek-v3-2-251201
VITE_TITLE_LLM_API_KEY=your_ark_api_key_here
