flowchart TB
    subgraph frontend [前端应用]
        HomePage[首页]
        RecordingPage[录制页]
        EditPage[录后编辑页]
        AnalysisPage[数据分析页]
        Vis3DPage[三维可视化页]
    end

    subgraph proxy [服务端代理层]
        WSProxy[网络套接字代理]
        GSheetsProxy[谷歌表格代理]
    end

    subgraph external [外部服务]
        VolcASR["火山引擎语音识别\n（流式+离线）"]
        GSheets["谷歌表格\n（数据标注）"]
    end

    RecordingPage -->|音频流| WSProxy
    WSProxy -->|认证转发| VolcASR
    VolcASR -->|转写结果| WSProxy
    WSProxy -->|实时字幕| RecordingPage
    EditPage -->|转录数据| GSheetsProxy
    GSheetsProxy -->|接口读写| GSheets
    GSheets -->|标注结果| GSheetsProxy
    GSheetsProxy -->|结构化数据| AnalysisPage
    AnalysisPage -->|映射数据| Vis3DPage
